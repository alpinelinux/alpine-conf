lbu_add_delete_body() {
	init_env
	mkdir -p root/.ssh
	atf_check -s exit:0 \
		-o match:"Adding root/.ssh to" \
		-e empty \
		lbu add -v root/.ssh

	atf_check -s exit:0 \
		-o match:"root/.ssh" \
		cat etc/apk/protected_paths.d/lbu.list

	atf_check -s exit:0 \
		-o match:"Removing root/.ssh from" \
		-e empty \
		lbu delete -v root/.ssh

	grep 'root/.ssh' etc/apk/protected_paths.d/lbu.list \
		|| atf_fail "root/.ssh was not removed"
}

